# Copie para .env (na pasta onde está vite.config.ts OU na pasta pai do projeto)
# Vercel: Project Settings > Environment Variables — mesmo nome com prefixo VITE_
# Login e APIs: URL + chave anon/public são obrigatórios.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Opcional (legado):
# VITE_SUPABASE_ANON_KEY=
# Nomes alternativos (sem VITE_) também são lidos pelo vite.config em dev/build:
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
